# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# PyInstaller
*.spec

# Installer logs
pip-log.txt

# Unit test / coverage reports
.cache/
.pytest_cache/
.coverage

# Environments
.env
.venv
env/
venv/
ENV/

# mypy
.mypy_cache/

# ===========================================
# Project-specific ignores
# ===========================================

# Backup directories
backup/
client_new/backup/

# Log directories and files
client_new/log/
server_new/logs/
*.log

# Connection config files (contains server addresses, ports)
# Use config.json.example as template when deploying
client_new/config.json
server_new/config.json

# Runtime generated files (can be deleted safely)
server_new/node_groups.json    # IP分组信息（运行时自动生成）
Transfer Files/                # 传输文件目录

# Update packages (generated by update_manager)
server_new/updates/

# Compiled executables
*.exe

# IDE / Editor specific
.qoder/
.idea/
.vscode/
.claude/

# Archives
*.zip
